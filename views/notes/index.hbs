<div class="row">
    <!-- Header -->
    <div class="col-12 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h1><i class="bi bi-journal-text"></i> Notes Manager</h1>
            <div>
                <button class="btn btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#createFolderModal">
                    <i class="bi bi-folder-plus"></i> New Folder
                </button>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadNoteModal">
                    <i class="bi bi-upload"></i> Upload Notes
                </button>
            </div>
        </div>
        <p class="text-muted">Upload, organize, and share your study notes. Search inside notes with OCR.</p>
    </div>

    <!-- Stats Cards -->
    <div class="col-md-3 col-6 mb-4">
        <div class="card bg-primary text-white">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.totalNotes}}</h1>
                <small>Total Notes</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-4">
        <div class="card bg-success text-white">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.totalSubjects}}</h1>
                <small>Subjects</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-4">
        <div class="card bg-info text-white">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.recentUploads}}</h1>
                <small>Last 7 Days</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-4">
        <div class="card bg-warning text-white">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{smartFileSize stats.totalSize}}</h1>
                <small>Total Size</small>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" id="searchNotes" placeholder="Search notes by title, subject, or content...">
                            <button class="btn btn-primary" onclick="searchNotes()">Search</button>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="filterSubject">
                            <option value="">All Subjects</option>
                            {{#each subjects}}
                            <option value="{{this}}">{{this}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Notes Grid -->
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-folder2-open"></i> All Notes
                        <span class="badge bg-secondary ms-2">{{notes.length}} files</span>
                    </h5>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="selectAllNotes">
                        <label class="form-check-label" for="selectAllNotes">Select All</label>
                    </div>
                </div>
            </div>
            <div class="card-body">
                {{#if notes.length}}
                <div class="row">
                    {{#each notes}}
                    <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                        <div class="card note-card h-100 border-{{#eq fileType 'pdf'}}danger{{else}}{{#eq fileType 'doc'}}primary{{else}}success{{/eq}}{{/eq}}">
                            <div class="card-header">
                                <div class="form-check">
                                    <input class="form-check-input note-checkbox" type="checkbox" value="{{_id}}">
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="text-center mb-3">
                                    {{#eq fileType 'pdf'}}
                                    <i class="bi bi-file-earmark-pdf-fill display-4 text-danger"></i>
                                    {{else eq fileType 'doc'}}
                                    <i class="bi bi-file-earmark-word-fill display-4 text-primary"></i>
                                    {{else eq fileType 'image'}}
                                    <i class="bi bi-file-earmark-image-fill display-4 text-success"></i>
                                    {{else}}
                                    <i class="bi bi-file-earmark-text-fill display-4 text-secondary"></i>
                                    {{/eq}}
                                </div>
                                <h6 class="card-title text-truncate" title="{{title}}">{{title}}</h6>
                                <div class="note-meta">
                                    <p class="small text-muted mb-1">
                                        <i class="bi bi-folder"></i> {{subject}}
                                    </p>
                                    <p class="small text-muted mb-1">
                                        <i class="bi bi-file-earmark"></i> {{fileType}}
                                        <span class="float-end">{{smartFileSize fileSize}}</span>
                                    </p>
                                    <p class="small text-muted">
                                        <i class="bi bi-calendar"></i> {{formatDate uploadDate}}
                                    </p>
                                </div>
                                {{#if tags.length}}
                                <div class="mb-2">
                                    {{#each tags}}
                                    <span class="badge bg-light text-dark border small me-1">{{this}}</span>
                                    {{/each}}
                                </div>
                                {{/if}}
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <div class="btn-group w-100">
                                    <a href="/notes/view/{{_id}}" class="btn btn-sm btn-outline-primary" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-success" onclick="shareNote('{{_id}}')" title="Share">
                                        <i class="bi bi-share"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-info" onclick="editNote('{{_id}}')" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteNote('{{_id}}')" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="text-center py-5">
                    <i class="bi bi-journal-text display-1 text-muted"></i>
                    <h4 class="mt-3">No notes uploaded yet</h4>
                    <p class="text-muted">Upload your first notes to get started</p>
                    <button class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#uploadNoteModal">
                        <i class="bi bi-upload"></i> Upload Notes
                    </button>
                </div>
                {{/if}}
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="col-12 mt-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-clock-history"></i> Recent Activity</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Action</th>
                                <th>Note</th>
                                <th>Subject</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each recentActivity}}
                            <tr>
                                <td>{{timeAgo}}</td>
                                <td>
                                    <span class="badge bg-{{actionColor}}">{{action}}</span>
                                </td>
                                <td>{{noteTitle}}</td>
                                <td>{{subject}}</td>
                            </tr>
                            {{else}}
                            <tr>
                                <td colspan="4" class="text-center text-muted">No recent activity</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Upload Note Modal -->
<div class="modal fade" id="uploadNoteModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload Notes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="uploadForm" action="/notes/upload" method="POST" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="subject" class="form-label">Subject *</label>
                            <input type="text" class="form-control" id="subject" name="subject" list="subjectList" required>
                            <datalist id="subjectList">
                                {{#each subjects}}
                                <option value="{{this}}">
                                {{/each}}
                            </datalist>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="title" class="form-label">Title *</label>
                            <input type="text" class="form-control" id="title" name="title" required>
                        </div>
                        <div class="col-12 mb-3">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" name="description" rows="2"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="noteFile" class="form-label">Select File *</label>
                            <input type="file" class="form-control" id="noteFile" name="noteFile" 
                                   accept=".pdf,.jpg,.jpeg,.png,.txt,.doc,.docx,.ppt,.pptx" required>
                            <div class="form-text">Max size: 10MB. Supported: PDF, Images, Docs, PPT</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="tags" class="form-label">Tags</label>
                            <input type="text" class="form-control" id="tags" name="tags" 
                                   placeholder="comma separated, e.g., important, chapter1, formulas">
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="enableOCR" name="enableOCR">
                                <label class="form-check-label" for="enableOCR">
                                    Enable OCR (Text extraction from images)
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic">
                                <label class="form-check-label" for="isPublic">
                                    Make public (shareable link)
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="progress mb-3" style="display: none;" id="uploadProgress">
                        <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="uploadButton">
                        <i class="bi bi-upload"></i> Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Note Modal -->
<div class="modal fade" id="editNoteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editNoteForm">
                <div class="modal-body" id="editNoteContent">
                    Loading...
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Share Note Modal -->
<div class="modal fade" id="shareNoteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Share Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="shareNoteContent">
                Loading...
            </div>
        </div>
    </div>
</div>

<!-- Create Folder Modal -->
<div class="modal fade" id="createFolderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Folder</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createFolderForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="folderName" class="form-label">Folder Name *</label>
                        <input type="text" class="form-control" id="folderName" required>
                    </div>
                    <div class="mb-3">
                        <label for="folderSubject" class="form-label">Subject</label>
                        <input type="text" class="form-control" id="folderSubject" list="subjectList">
                    </div>
                    <div class="mb-3">
                        <label for="folderColor" class="form-label">Color</label>
                        <input type="color" class="form-control" id="folderColor" value="#0d6efd">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Folder</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// ============= DOM READY =============
document.addEventListener('DOMContentLoaded', function() {
    console.log('Notes manager loaded');
    
    // Select all notes checkbox
    const selectAllCheckbox = document.getElementById('selectAllNotes');
    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.note-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });
    }
    
    // Search input - enable enter key
    const searchInput = document.getElementById('searchNotes');
    if (searchInput) {
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchNotes();
            }
        });
    }
    
    // Filter by subject
    const filterSubject = document.getElementById('filterSubject');
    if (filterSubject) {
        filterSubject.addEventListener('change', function() {
            filterNotesBySubject(this.value);
        });
    }
});

// ============= SEARCH FUNCTIONS =============
function searchNotes() {
    const query = document.getElementById('searchNotes').value.trim();
    
    if (!query) {
        alert('Please enter a search term');
        return;
    }
    
    // Redirect to search route
    window.location.href = `/notes/search?q=${encodeURIComponent(query)}`;
}

// ============= FILTER FUNCTIONS =============
function filterNotesBySubject(subject) {
    const noteCards = document.querySelectorAll('.note-card');
    
    noteCards.forEach(card => {
        const subjectElement = card.querySelector('.note-meta p:first-child');
        if (!subjectElement) return;
        
        const cardSubject = subjectElement.textContent.toLowerCase();
        
        if (!subject || cardSubject.includes(subject.toLowerCase())) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

// ============= NOTE OPERATIONS =============
async function shareNote(noteId) {
    try {
        console.log('Sharing note:', noteId);
        const response = await fetch(`/notes/share/${noteId}`);
        const data = await response.json();
        
        if (!data.shareableLink) {
            throw new Error('No shareable link returned');
        }
        
        const content = `
            <div class="text-center">
                <i class="bi bi-share display-4 text-success mb-3"></i>
                <h5>Share this note</h5>
                <div class="alert alert-info">
                    <small>Anyone with this link can view your note</small>
                </div>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" value="${data.shareableLink}" id="shareLink" readonly>
                    <button class="btn btn-outline-secondary" type="button" onclick="copyShareLink()">
                        <i class="bi bi-clipboard"></i> Copy
                    </button>
                </div>
                <p class="text-muted small">
                    <i class="bi bi-info-circle"></i>
                    The link will work for anyone who receives it.
                </p>
            </div>
        `;
        
        document.getElementById('shareNoteContent').innerHTML = content;
        const modal = new bootstrap.Modal(document.getElementById('shareNoteModal'));
        modal.show();
        
    } catch (error) {
        console.error('Error sharing note:', error);
        alert('Failed to get share link. Please try again.');
    }
}

function copyShareLink() {
    const linkInput = document.getElementById('shareLink');
    if (!linkInput) return;
    
    linkInput.select();
    linkInput.setSelectionRange(0, 99999);
    
    try {
        navigator.clipboard.writeText(linkInput.value)
            .then(() => {
                // Show success feedback
                const copyBtn = linkInput.nextElementSibling;
                const originalHTML = copyBtn.innerHTML;
                copyBtn.innerHTML = '<i class="bi bi-check"></i> Copied!';
                copyBtn.classList.add('btn-success');
                copyBtn.classList.remove('btn-outline-secondary');
                
                setTimeout(() => {
                    copyBtn.innerHTML = originalHTML;
                    copyBtn.classList.remove('btn-success');
                    copyBtn.classList.add('btn-outline-secondary');
                }, 2000);
            })
            .catch(err => {
                console.error('Failed to copy:', err);
                alert('Failed to copy to clipboard');
            });
    } catch (err) {
        // Fallback for older browsers
        document.execCommand('copy');
        alert('Link copied to clipboard');
    }
}

async function editNote(noteId) {
    try {
        console.log('Editing note:', noteId);
        const response = await fetch(`/notes/${noteId}`);
        if (!response.ok) {
            throw new Error('Failed to fetch note');
        }
        
        const note = await response.json();
        
        const content = `
            <div class="mb-3">
                <label class="form-label">Title *</label>
                <input type="text" class="form-control" id="editTitle" value="${note.title.replace(/"/g, '&quot;')}" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Subject *</label>
                <input type="text" class="form-control" id="editSubject" value="${note.subject.replace(/"/g, '&quot;')}" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" id="editDescription" rows="3">${note.description || ''}</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Tags (comma separated)</label>
                <input type="text" class="form-control" id="editTags" value="${note.tags ? note.tags.map(t => t.replace(/"/g, '&quot;')).join(', ') : ''}">
            </div>
            <input type="hidden" id="editNoteId" value="${noteId}">
        `;
        
        document.getElementById('editNoteContent').innerHTML = content;
        
        // Setup form submission
        const editForm = document.getElementById('editNoteForm');
        if (editForm) {
            editForm.onsubmit = async function(e) {
                e.preventDefault();
                
                const updateData = {
                    title: document.getElementById('editTitle').value.trim(),
                    subject: document.getElementById('editSubject').value.trim(),
                    description: document.getElementById('editDescription').value.trim(),
                    tags: document.getElementById('editTags').value.split(',').map(tag => tag.trim()).filter(tag => tag !== '')
                };
                
                if (!updateData.title || !updateData.subject) {
                    alert('Title and Subject are required');
                    return;
                }
                
                try {
                    const updateResponse = await fetch(`/notes/${noteId}`, {
                        method: 'PUT',
                        headers: { 
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify(updateData)
                    });
                    
                    const result = await updateResponse.json();
                    
                    if (result.success) {
                        alert('Note updated successfully!');
                        bootstrap.Modal.getInstance(document.getElementById('editNoteModal')).hide();
                        // Reload after a short delay
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    console.error('Error updating note:', error);
                    alert('Failed to update note');
                }
            };
        }
        
        const modal = new bootstrap.Modal(document.getElementById('editNoteModal'));
        modal.show();
        
    } catch (error) {
        console.error('Error loading note:', error);
        alert('Failed to load note data');
    }
}

function deleteNote(noteId) {
    if (!confirm('Are you sure you want to delete this note? This action cannot be undone.')) {
        return;
    }
    
    fetch(`/notes/${noteId}`, {
        method: 'DELETE',
        headers: {
            'Accept': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Note deleted successfully!');
            // Remove the note card from UI
            const noteCard = document.querySelector(`[value="${noteId}"]`).closest('.col-xl-3');
            if (noteCard) {
                noteCard.style.opacity = '0.5';
                setTimeout(() => {
                    noteCard.remove();
                    // Update the note count
                    const badge = document.querySelector('.card-header .badge');
                    if (badge) {
                        const currentCount = parseInt(badge.textContent) - 1;
                        badge.textContent = `${currentCount} files`;
                    }
                }, 500);
            }
        } else {
            alert('Error: ' + data.error);
        }
    })
    .catch(error => {
        console.error('Error deleting note:', error);
        alert('Failed to delete note');
    });
}

// ============= FOLDER CREATION =============
document.getElementById('createFolderForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const folderData = {
        name: document.getElementById('folderName').value.trim(),
        subject: document.getElementById('folderSubject').value.trim() || 'General',
        color: document.getElementById('folderColor').value
    };
    
    if (!folderData.name) {
        alert('Folder name is required');
        return;
    }
    
    try {
        const response = await fetch('/notes/folder', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(folderData)
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('Folder created successfully!');
            const modal = bootstrap.Modal.getInstance(document.getElementById('createFolderModal'));
            if (modal) modal.hide();
            // Clear form
            this.reset();
            // Reload page to show new folder
            setTimeout(() => {
                window.location.reload();
            }, 1500);
        } else {
            alert('Error: ' + data.error);
        }
    } catch (error) {
        console.error('Error creating folder:', error);
        alert('Failed to create folder');
    }
});

// Add CSS for animations
const style = document.createElement('style');
style.textContent = `
@keyframes highlight {
    0% { background-color: transparent; }
    50% { background-color: #fff3cd; }
    100% { background-color: transparent; }
}

.note-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, opacity 0.5s ease;
}

.note-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
}
`;
document.head.appendChild(style);
</script>