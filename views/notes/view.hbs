<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/notes">Notes</a></li>
                    <li class="breadcrumb-item active">{{note.title}}</li>
                </ol>
            </nav>
            
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0">
                            <i class="bi {{#if isPDF}}bi-file-earmark-pdf text-danger{{else if isImage}}bi-image text-success{{else}}bi-file-earmark-text{{/if}}"></i>
                            {{note.title}}
                        </h4>
                        <div class="btn-group">
                            <a href="/notes/download/{{note._id}}" class="btn btn-outline-success">
                                <i class="bi bi-download"></i> Download
                            </a>
                            <a href="/notes" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h6 class="mb-0">Note Details</h6>
                                </div>
                                <div class="card-body">
                                    <p><strong>Subject:</strong> <span class="badge bg-info">{{note.subject}}</span></p>
                                    <p><strong>File Type:</strong> <span class="badge bg-secondary">{{note.fileType}}</span></p>
                                    <p><strong>File Size:</strong> {{formatFileSize note.fileSize}}</p>
                                    <p><strong>Upload Date:</strong> {{formatDate note.uploadDate}}</p>
                                    
                                    {{#if note.description}}
                                    <p><strong>Description:</strong></p>
                                    <p class="text-muted">{{note.description}}</p>
                                    {{/if}}
                                    
                                    {{#if note.tags.length}}
                                    <p><strong>Tags:</strong></p>
                                    <div>
                                        {{#each note.tags}}
                                        <span class="badge bg-light text-dark border me-1">{{this}}</span>
                                        {{/each}}
                                    </div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-8">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">Preview</h6>
                                </div>
                                <div class="card-body" style="min-height: 500px;">
                                    {{#if isPDF}}
                                    <div class="text-center">
                                        <iframe src="{{fileUrl}}" 
                                                style="width: 100%; height: 450px;" 
                                                frameborder="0">
                                        </iframe>
                                        <p class="mt-2 text-muted">
                                            <small>If the PDF doesn't load, <a href="{{fileUrl}}" target="_blank">click here</a> to view it.</small>
                                        </p>
                                    </div>
                                    {{else if isImage}}
                                    <div class="text-center">
                                        <img src="{{fileUrl}}" 
                                             alt="{{note.title}}" 
                                             class="img-fluid rounded" 
                                             style="max-height: 450px;">
                                    </div>
                                    {{else}}
                                    <div class="text-center py-5">
                                        <i class="bi bi-file-earmark-text display-1 text-muted"></i>
                                        <h4 class="mt-3">Preview not available</h4>
                                        <p class="text-muted">Download the file to view its contents</p>
                                        <a href="/notes/download/{{note._id}}" class="btn btn-primary">
                                            <i class="bi bi-download"></i> Download File
                                        </a>
                                    </div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Auto-resize iframe for PDF
document.addEventListener('DOMContentLoaded', function() {
    const iframe = document.querySelector('iframe');
    if (iframe) {
        iframe.onload = function() {
            this.style.height = this.contentWindow.document.body.scrollHeight + 'px';
        };
    }
});
</script>