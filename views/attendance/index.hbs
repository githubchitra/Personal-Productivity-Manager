<div class="container mt-4">
    <div class="row">
        <div class="col-12 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <h1><i class="bi bi-calendar-check"></i> Attendance Tracker</h1>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSubjectModal">
                    <i class="bi bi-plus-circle"></i> Add Subject
                </button>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h1 class="display-4">{{safeSubjects}}</h1>
                    <p class="card-text">Safe Subjects (≥75%)</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <h1 class="display-4">{{atRiskSubjects}}</h1>
                    <p class="card-text">At Risk (60-75%)</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h1 class="display-4">{{criticalSubjects}}</h1>
                    <p class="card-text">Critical (<60%)</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h1 class="display-4">{{totalSubjects}}</h1>
                    <p class="card-text">Total Subjects</p>
                </div>
            </div>
        </div>

        <!-- Attendance Table -->
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Subject-wise Attendance</h5>
                </div>
                <div class="card-body">
                    {{#if attendance.length}}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Subject</th>
                                    <th>Attended</th>
                                    <th>Total</th>
                                    <th>Percentage</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each attendance}}
                                <tr>
                                    <td>{{this.subject}}</td>
                                    <td>{{this.attendedClasses}}</td>
                                    <td>{{this.totalClasses}}</td>
                                    <td>
                                        {{progressBar this.percentage}}
                                        <small class="text-muted">{{formatPercentage this.percentage}}%</small>
                                    </td>
                                    <td>
                                        {{#if (gt this.percentage 74)}}
                                        <span class="badge bg-success">Safe</span>
                                        {{else if (gt this.percentage 59)}}
                                        <span class="badge bg-warning">At Risk</span>
                                        {{else}}
                                        <span class="badge bg-danger">Critical</span>
                                        {{/if}}
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <!-- Present Button -->
                                            <form action="/attendance/update/{{this._id}}" method="POST">
                                                <input type="hidden" name="action" value="present">
                                                <button type="submit" class="btn btn-success btn-sm me-1">
                                                    <i class="bi bi-check-circle"></i> Present
                                                </button>
                                            </form>

                                            <!-- Absent Button -->
                                            <form action="/attendance/update/{{this._id}}" method="POST">
                                                <input type="hidden" name="action" value="absent">
                                                <button type="submit" class="btn btn-danger btn-sm me-1">
                                                    <i class="bi bi-x-circle"></i> Absent
                                                </button>
                                            </form>
                                            
                                            <!-- Delete Button -->
                                            <form action="/attendance/delete/{{this._id}}" method="POST" 
                                                  onsubmit="return confirm('Are you sure you want to delete this subject?');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                    {{else}}
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x display-1 text-muted"></i>
                        <h4 class="mt-3">No attendance records found</h4>
                        <p class="text-muted">Add your first subject to start tracking attendance</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSubjectModal">
                            <i class="bi bi-plus-circle"></i> Add Your First Subject
                        </button>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Subject Modal -->
<div class="modal fade" id="addSubjectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Subject</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/attendance/add" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="subject" class="form-label">Subject Name</label>
                        <input type="text" class="form-control" id="subject" name="subject" required 
                               placeholder="e.g., Mathematics, Physics">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="totalClasses" class="form-label">Total Classes Held</label>
                            <input type="number" class="form-control" id="totalClasses" name="totalClasses" 
                                   min="0" required value="0">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="attendedClasses" class="form-label">Classes Attended</label>
                            <input type="number" class="form-control" id="attendedClasses" name="attendedClasses"
                                   min="0" required value="0">
                        </div>
                    </div>
                    <div class="alert alert-info">
                        <small>
                            <i class="bi bi-info-circle"></i> 
                            After adding, you can update attendance daily using the Present/Absent buttons.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Add Subject</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Success/Error Messages -->
{{#if success}}
<div class="position-fixed top-0 end-0 p-3" style="z-index: 11">
    <div class="toast show" role="alert">
        <div class="toast-header bg-success text-white">
            <strong class="me-auto">Success</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">
            {{success}}
        </div>
    </div>
</div>
{{/if}}

{{#if error}}
<div class="position-fixed top-0 end-0 p-3" style="z-index: 11">
    <div class="toast show" role="alert">
        <div class="toast-header bg-danger text-white">
            <strong class="me-auto">Error</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">
            {{error}}
        </div>
    </div>
</div>
{{/if}}

<style>
    .progress {
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 5px;
    }
    .progress-bar {
        transition: width 0.5s ease;
        font-weight: bold;
    }
    .btn-group form {
        display: inline-block;
    }
</style>

<script>
    // Auto-close toasts after 5 seconds
    document.addEventListener('DOMContentLoaded', function() {
        const toasts = document.querySelectorAll('.toast');
        toasts.forEach(toast => {
            setTimeout(() => {
                const bsToast = bootstrap.Toast.getOrCreateInstance(toast);
                bsToast.hide();
            }, 5000);
        });
        
        // Form validation for add subject
        const addForm = document.querySelector('form[action="/attendance/add"]');
        if (addForm) {
            addForm.addEventListener('submit', function(e) {
                const total = parseInt(document.getElementById('totalClasses').value);
                const attended = parseInt(document.getElementById('attendedClasses').value);
                
                if (attended > total) {
                    e.preventDefault();
                    alert('Attended classes cannot be more than total classes');
                    return false;
                }
            });
        }
    });
</script>