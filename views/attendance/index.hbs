<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-4 align-items-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-1"><i class="bi bi-calendar-check-fill text-primary me-2"></i>Attendance Tracker</h1>
            <p class="text-muted">Manage your subject-wise attendance and stay above the {{stats.overallThreshold}}%
                threshold.</p>
        </div>
        <div class="col-lg-4 text-lg-end">
            <button class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm" data-bs-toggle="modal"
                data-bs-target="#addSubjectModal">
                <i class="bi bi-plus-lg me-2"></i>Add New Subject
            </button>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card card-premium text-center p-4">
                <div class="d-flex justify-content-center mb-3">
                    <div class="rounded-circle bg-light p-3">
                        <i class="bi bi-percent fs-3 text-primary"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-0">{{stats.overallPercentage}}%</h2>
                <p class="text-muted mb-0 small uppercase fw-bold tracking-wider">Overall Attendance</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium text-center p-4 border-bottom border-success border-5">
                <h2 class="fw-bold mb-0">{{stats.safeSubjects}}</h2>
                <p class="text-muted mb-0 small">Safe Subjects</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium text-center p-4 border-bottom border-warning border-5">
                <h2 class="fw-bold mb-0">{{stats.atRiskSubjects}}</h2>
                <p class="text-muted mb-0 small">At Risk</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-premium text-center p-4 border-bottom border-danger border-5">
                <h2 class="fw-bold mb-0">{{stats.criticalSubjects}}</h2>
                <p class="text-muted mb-0 small">Critical Action Needed</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Table -->
        <div class="col-xl-8">
            <div class="card card-premium h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">Subject Breakdown</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small uppercase">
                                <tr>
                                    <th class="ps-4 py-3">Subject</th>
                                    <th>Progress</th>
                                    <th>Status</th>
                                    <th>Requirement</th>
                                    <th class="pe-4">Quick Mark</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each attendance}}
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">{{this.subject}}</div>
                                        <small class="text-muted">{{this.attendedClasses}} of {{this.totalClasses}}
                                            classes</small>
                                    </td>
                                    <td style="min-width: 150px;">
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                                <div class="progress-bar {{#if (eq this.status 'safe')}}bg-primary{{else if (eq this.status 'atRisk')}}bg-warning{{else}}bg-danger{{/if}}"
                                                    style="width: {{this.percentage}}%"></div>
                                            </div>
                                            <span class="small fw-bold">{{this.percentage}}%</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span
                                            class="badge rounded-pill {{#if (eq this.status 'safe')}}bg-success{{else if (eq this.status 'atRisk')}}bg-warning text-dark{{else}}bg-danger{{/if}}">
                                            {{this.status}}
                                        </span>
                                    </td>
                                    <td>
                                        {{#if (gt this.classesNeeded 0)}}
                                        <span class="text-danger small fw-bold"><i
                                                class="bi bi-exclamation-triangle-fill"></i> Attend next
                                            {{this.classesNeeded}} classes</span>
                                        {{else}}
                                        <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill"></i>
                                            On track</span>
                                        {{/if}}
                                    </td>
                                    <td class="pe-4">
                                        <div class="btn-group shadow-sm">
                                            <form action="/attendance/update/{{this._id}}" method="POST">
                                                <input type="hidden" name="action" value="present">
                                                <button type="submit" class="btn btn-sm btn-white border-end"
                                                    title="Mark Present">
                                                    <i class="bi bi-check text-success fs-5"></i>
                                                </button>
                                            </form>
                                            <form action="/attendance/update/{{this._id}}" method="POST">
                                                <input type="hidden" name="action" value="absent">
                                                <button type="submit" class="btn btn-sm btn-white border-end"
                                                    title="Mark Absent">
                                                    <i class="bi bi-x text-danger fs-5"></i>
                                                </button>
                                            </form>
                                            <form action="/attendance/delete/{{this._id}}" method="POST">
                                                <button type="submit" class="btn btn-sm btn-white text-muted"
                                                    onclick="return confirm('Delete this subject?')">
                                                    <i class="bi bi-trash fs-6"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Risk Predictor Sidebar -->
        <div class="col-xl-4">
            <div class="card card-premium">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Risk Predictor</h5>
                    <span class="badge bg-light text-dark fw-normal">4-Week Projection</span>
                </div>
                <div class="card-body pt-0">
                    <div id="riskContainer">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                            <p class="small text-muted mt-2">Analyzing attendance patterns...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Management Card -->
            <div class="card card-premium mt-4 bg-primary text-white">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Global Settings</h6>
                    <div class="mb-3">
                        <label class="small opacity-75 d-block">Required Threshold</label>
                        <div class="h3 fw-bold">75%</div>
                    </div>
                    <button class="btn btn-light btn-sm w-100 rounded-pill fw-bold text-primary">Edit Settings</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addSubjectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Add New Subject</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/attendance/add" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Subject Title</label>
                        <input type="text" class="form-control rounded-3" name="subject" required
                            placeholder="e.g. Data Structures">
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Total Sessions</label>
                            <input type="number" class="form-control rounded-3" name="totalClasses" min="0" value="0"
                                required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Attended Sessions</label>
                            <input type="number" class="form-control rounded-3" name="attendedClasses" min="0" value="0"
                                required>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Weekly Classes</label>
                            <input type="number" class="form-control rounded-3" name="weeklyClassCount" min="1"
                                value="4" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Threshold (%)</label>
                            <input type="number" class="form-control rounded-3" name="threshold" min="0" max="100"
                                value="75" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">Create Tracker</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Risk analysis fetch
        fetch('/attendance/risk')
            .then(res => res.json())
            .then(data => {
                const container = document.getElementById('riskContainer');
                if (!data.length) {
                    container.innerHTML = '<p class="text-center text-muted py-4">Add subjects to see risk analysis</p>';
                    return;
                }

                container.innerHTML = data.map(risk => `
                <div class="py-3 border-bottom last-child-noborder">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold">${risk.subject}</span>
                        <span class="badge ${risk.canMissNext > 0 ? 'bg-success-light text-success' : 'bg-danger-light text-danger'} rounded-pill px-2">
                            ${risk.canMissNext > 0 ? 'Safe' : 'Critical'}
                        </span>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="progress flex-grow-1 me-2" style="height: 4px;">
                            <div class="progress-bar ${risk.canMissNext > 0 ? 'bg-success' : 'bg-danger'}" style="width: ${risk.percentage}%"></div>
                        </div>
                    </div>
                    <p class="small text-muted mt-2 mb-0">
                        ${risk.canMissNext > 0
                        ? `<i class="bi bi-check2-circle text-success"></i> You can miss <strong>${risk.canMissNext}</strong> more classes in next 4 weeks.`
                        : `<i class="bi bi-exclamation-circle text-danger"></i> <strong>Must attend</strong> all upcoming classes to recover.`}
                    </p>
                </div>
            `).join('');
            });
    });
</script>

<style>
    .bg-success-light {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-danger-light {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .last-child-noborder:last-child {
        border-bottom: none !important;
    }

    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
    }

    .btn-white {
        background: #fff;
        color: #444;
    }

    .btn-white:hover {
        background: #f8f9fa;
    }
</style>