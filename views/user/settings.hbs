<div class="container py-5">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3">
            <div class="nav flex-column nav-pills card card-premium p-3 gap-2" id="v-pills-tab" role="tablist">
                <button class="nav-link active rounded-pill text-start py-2 px-3 fw-bold border-0"
                    id="v-pills-general-tab" data-bs-toggle="pill" data-bs-target="#v-pills-general" type="button"
                    role="tab"><i class="bi bi-gear me-2"></i>General</button>
                <button class="nav-link rounded-pill text-start py-2 px-3 fw-bold border-0" id="v-pills-security-tab"
                    data-bs-toggle="pill" data-bs-target="#v-pills-security" type="button" role="tab"><i
                        class="bi bi-shield-lock me-2"></i>Security</button>
                <button class="nav-link rounded-pill text-start py-2 px-3 fw-bold border-0"
                    id="v-pills-notifications-tab" data-bs-toggle="pill" data-bs-target="#v-pills-notifications"
                    type="button" role="tab"><i class="bi bi-bell me-2"></i>Notifications</button>
                <div class="dropdown-divider my-2"></div>
                <a href="/profile" class="nav-link rounded-pill text-start py-2 px-3 fw-bold text-muted border-0"><i
                        class="bi bi-arrow-left me-2 text-primary"></i>Back to Profile</a>
            </div>
        </div>

        <!-- Content Area -->
        <div class="col-lg-9">
            <div class="tab-content" id="v-pills-tabContent">
                <!-- General Settings -->
                <div class="tab-pane fade show active" id="v-pills-general" role="tabpanel">
                    <div class="card card-premium">
                        <div class="card-header bg-white py-3 border-0">
                            <h5 class="fw-bold mb-0">General Settings</h5>
                        </div>
                        <div class="card-body">
                            <form action="/profile/update" method="POST">
                                <div class="row g-4 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted">User Handle</label>
                                        <div class="input-group">
                                            <span
                                                class="input-group-text bg-light rounded-start-pill border-end-0">@</span>
                                            <input type="text"
                                                class="form-control rounded-end-pill bg-light border-start-0"
                                                value="{{user.username}}" readonly>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted">Primary Email</label>
                                        <input type="email" class="form-control rounded-pill bg-light"
                                            value="{{user.email}}" readonly>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check form-switch p-0 ps-5 mt-2">
                                            <input class="form-check-input" type="checkbox" id="publicProfile" checked>
                                            <label class="form-check-label fw-bold small text-muted ms-2"
                                                for="publicProfile">Public Profile (Anyone can see your profile)</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary rounded-pill px-5">Save
                                        General</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Security Settings -->
                <div class="tab-pane fade" id="v-pills-security" role="tabpanel">
                    <div class="card card-premium">
                        <div class="card-header bg-white py-3 border-0">
                            <h5 class="fw-bold mb-0">Security Settings</h5>
                        </div>
                        <div class="card-body">
                            {{#if error}}
                            <div class="alert alert-danger rounded-3" role="alert">
                                <i class="bi bi-exclamation-octagon me-2"></i>{{error}}
                            </div>
                            {{/if}}
                            {{#if success}}
                            <div class="alert alert-success rounded-3" role="alert">
                                <i class="bi bi-check2-circle me-2"></i>{{success}}
                            </div>
                            {{/if}}

                            <form action="/settings/security" method="POST">
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted">Current Password</label>
                                    <input type="password" class="form-control rounded-pill" name="currentPassword"
                                        required placeholder="••••••••">
                                </div>
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted">New Password</label>
                                        <input type="password" class="form-control rounded-pill" name="newPassword"
                                            required placeholder="New password">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted">Confirm New Password</label>
                                        <input type="password" class="form-control rounded-pill" name="confirmPassword"
                                            required placeholder="Confirm new password">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <a href="#" class="text-muted small">Forgot your password?</a>
                                    <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold">Update
                                        Password</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Notifications Settings -->
                <div class="tab-pane fade" id="v-pills-notifications" role="tabpanel">
                    <div class="card card-premium">
                        <div class="card-header bg-white py-3 border-0">
                            <h5 class="fw-bold mb-0">Notification Preferences</h5>
                        </div>
                        <div class="card-body">
                            <div class="list-group list-group-flush gap-3">
                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">Email Notifications</h6>
                                        <p class="small text-muted mb-0">Receive weekly study reports and digests.</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="emailNotif" checked>
                                    </div>
                                </div>
                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">Attendance Alerts</h6>
                                        <p class="small text-muted mb-0">Notify me when my attendance drops below 75%.
                                        </p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="attNotif" checked>
                                    </div>
                                </div>
                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1 fw-bold">Opportunity Digest</h6>
                                        <p class="small text-muted mb-0">New jobs, internships, and hackathons
                                            notifications.</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="oppNotif" checked>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: #555;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .nav-pills .nav-link.active {
        background-color: var(--primary) !important;
        color: white !important;
        transform: translateX(5px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .nav-pills .nav-link:hover:not(.active) {
        background-color: #f8f9fa;
        transform: translateX(3px);
    }

    .rounded-start-pill {
        border-top-left-radius: 50px !important;
        border-bottom-left-radius: 50px !important;
    }

    .rounded-end-pill {
        border-top-right-radius: 50px !important;
        border-bottom-right-radius: 50px !important;
    }
</style>