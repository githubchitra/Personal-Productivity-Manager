<div class="container-fluid py-4 study-planner-container">
    <!-- Main Heading -->
    <div class="header-section mb-5 animate__animated animate__fadeInDown">
        <h1 class="display-5 fw-bold text-dark mb-2">Smart Study Planner</h1>
        <p class="lead text-muted opacity-75">AI-assisted weekly study plan based on your focus subjects and
            availability.</p>
        <div class="d-flex align-items-center mt-3 gap-2">
            <button type="button" id="generateBtn"
                class="btn btn-generate-plan btn-lg rounded-pill px-5 py-3 shadow-lg">
                <i class="bi bi-magic me-2"></i>Generate Plan
            </button>
            <button type="button" id="downloadPdfBtn"
                class="btn btn-outline-dark btn-lg rounded-pill px-4 py-3 {{#unless currentPlan}}d-none{{/unless}} shadow-sm">
                <i class="bi bi-file-earmark-pdf me-2"></i>Download PDF
            </button>
            <div id="loadingSpinner" class="ms-3 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="ms-2 text-primary fw-bold">AI is thinking...</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Current Week's Schedule -->
        <div class="col-xl-8 animate__animated animate__fadeInLeft">
            <div class="card card-premium mb-4 border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold mb-0 text-primary-gradient"><i class="bi bi-calendar3 me-2"></i>Current Week's
                        Schedule</h4>
                </div>
                <div class="card-body px-4 pb-4" id="planContainer">
                    {{#if currentPlan}}
                    <div class="row g-3">
                        {{#each currentPlan.plan}}
                        <div class="col-md">
                            <div class="day-card-modern p-3 h-100 rounded-4 transition-transform shadow-hover">
                                <h6 class="fw-bold text-uppercase tiny tracking-wider mb-3 text-muted">{{this.day}}</h6>
                                <div class="slots">
                                    {{#if this.slots.length}}
                                    {{#each this.slots}}
                                    <div
                                        class="subject-card mb-2 p-3 rounded-4 shadow-sm border-0 animate__animated animate__fadeInUp bg-white">
                                        <div class="d-flex align-items-start justify-content-between">
                                            <div>
                                                <div class="fw-bold text-dark small">{{this.subject}}</div>
                                                <div class="text-muted tiny mt-1">
                                                    <i class="bi bi-clock-history me-1"></i>{{this.duration}}h
                                                </div>
                                            </div>
                                            <div class="subject-icon text-primary opacity-50">
                                                <i class="bi bi-book"></i>
                                            </div>
                                        </div>
                                        <div class="mt-2 text-end">
                                            <span
                                                class="badge badge-soft-primary rounded-pill tiny">{{this.startTime}}</span>
                                        </div>
                                    </div>
                                    {{/each}}
                                    {{else}}
                                    <div class="empty-day text-center py-4 rounded-4">
                                        <i class="bi bi-brightness-high text-warning-gradient opacity-50 display-6"></i>
                                        <p class="tiny text-muted mt-2 mb-0">Free Day</p>
                                    </div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="empty-state text-center py-5 rounded-5 bg-light-gradient">
                        <div class="floating mb-4">
                            <i class="bi bi-calendar2-range display-1 text-primary-gradient opacity-25"></i>
                        </div>
                        <h4 class="fw-bold">Awaiting Schedule</h4>
                        <p class="text-muted mb-0">No plan is set for this week. Hit "Generate Plan" or configure
                            preferences.</p>
                    </div>
                    {{/if}}
                </div>
            </div>

            <!-- Timeline Cards -->
            <div class="row g-3 mt-1">
                <div class="col-md">
                    <div
                        class="timeline-event-card p-3 rounded-4 bg-primary text-white text-center shadow-lg animate__animated animate__zoomIn">
                        <div class="small fw-bold text-uppercase tiny opacity-75 mb-1">Today</div>
                        <div class="fw-bold h6 mb-0">Weekly Sync</div>
                    </div>
                </div>
                <div class="col-md">
                    <div
                        class="timeline-event-card p-3 rounded-4 bg-warning text-white text-center shadow shadow-hover animate__animated animate__zoomIn animate__delay-1s">
                        <div class="small fw-bold text-uppercase tiny opacity-75 mb-1">Apr 15</div>
                        <div class="fw-bold h6 mb-0">Midterms</div>
                    </div>
                </div>
                <div class="col-md">
                    <div
                        class="timeline-event-card p-3 rounded-4 bg-danger text-white text-center shadow shadow-hover animate__animated animate__zoomIn animate__delay-2s">
                        <div class="small fw-bold text-uppercase tiny opacity-75 mb-1">May 20</div>
                        <div class="fw-bold h6 mb-0">Viva</div>
                    </div>
                </div>
                <div class="col-md">
                    <div
                        class="timeline-event-card p-3 rounded-4 bg-secondary text-white text-center shadow-hover animate__animated animate__zoomIn animate__delay-3s opacity-75 border-dash">
                        <div class="small fw-bold text-uppercase tiny opacity-75 mb-1">June 02</div>
                        <div class="fw-bold h6 mb-0">End Sem</div>
                    </div>
                </div>
            </div>

            <!-- AI Tip Section -->
            <div class="ai-tip-banner mt-5 p-4 rounded-5 shadow-lg animate__animated animate__slideInUp">
                <div class="d-flex align-items-center">
                    <div
                        class="ai-icon-box me-4 bg-white rounded-circle d-flex align-items-center justify-content-center">
                        <i class="bi bi-lightbulb-fill text-warning fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1 text-white">AI Suggestion</h6>
                        <p class="mb-0 text-white-50" id="aiTipText">Prioritize subjects with 'Critical' attendance risk
                            first. Consistency is key!</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Preferences Panel -->
        <div class="col-xl-4 animate__animated animate__fadeInRight">
            <div class="card card-premium sticky-top border-0" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center text-dark">
                        <i class="bi bi-sliders2-vertical me-2 text-primary"></i> Preferences Panel
                    </h5>

                    <form id="preferencesForm">
                        <div class="preference-group mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-3">Daily Available
                                Hours</label>
                            <div class="input-group input-group-lg bg-light rounded-pill overflow-hidden border">
                                <span class="input-group-text bg-transparent border-0 ps-3">
                                    <i class="bi bi-hourglass-split text-primary"></i>
                                </span>
                                <input type="number" step="1" min="1" max="24"
                                    class="form-control bg-transparent border-0 py-3" name="availableHours" value=""
                                    id="dailyHoursInput" placeholder="Enter hours">
                            </div>
                        </div>

                        <div class="preference-group mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-3">Academic
                                Timeline</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="date" class="form-control bg-light border-0 rounded-4 py-3"
                                        id="startDateInput" value="">
                                </div>
                                <div class="col-6">
                                    <input type="date" class="form-control bg-light border-0 rounded-4 py-3"
                                        id="endDateInput" value="">
                                </div>
                            </div>
                        </div>

                        <div class="preference-group mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <label class="form-label small fw-bold text-muted text-uppercase mb-0">Focus
                                    Subjects</label>
                                <button type="button" class="btn btn-soft-primary btn-sm rounded-pill px-3"
                                    onclick="addSubjectFieldModern()">
                                    <i class="bi bi-plus-lg me-1"></i>Add Subject
                                </button>
                            </div>

                            <div id="focusSubjectsListModern">
                                {{#each preferences.focusSubjects}}
                                <div
                                    class="subject-pill d-flex align-items-center bg-light rounded-pill p-2 mb-2 animate__animated animate__fadeIn">
                                    <div class="subject-color-dot me-2"></div>
                                    <input type="text"
                                        class="form-control form-control-sm bg-transparent border-0 flex-grow-1"
                                        name="subjects[]" value="{{this.subject}}">
                                    <button class="btn btn-link text-danger btn-sm border-0" type="button"
                                        onclick="this.parentElement.remove()">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                                {{/each}}
                                {{#unless preferences.focusSubjects.length}}
                                <div class="text-center py-3 text-muted tiny">
                                    No subjects added yet. Click "+ Add Subject" to start.
                                </div>
                                {{/unless}}
                            </div>
                        </div>

                        <button type="button"
                            class="btn btn-primary btn-lg w-100 rounded-pill py-3 shadow-lg mt-3 transition-transform"
                            id="savePrefsBtn">
                            <i class="bi bi-save me-2"></i>Save Preferences
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // UI Interactions
    function addSubjectFieldModern() {
        const list = document.getElementById('focusSubjectsListModern');
        const div = document.createElement('div');
        div.className = 'subject-pill d-flex align-items-center bg-light rounded-pill p-2 mb-2 animate__animated animate__bounceIn';
        div.innerHTML = `
        <div class="subject-color-dot me-2 bg-primary"></div>
        <input type="text" class="form-control form-control-sm bg-transparent border-0 flex-grow-1" name="subjects[]" placeholder="Subject name">
        <button class="btn btn-link text-danger btn-sm border-0" type="button" onclick="this.parentElement.remove()">
            <i class="bi bi-x-circle"></i>
        </button>
    `;
        list.appendChild(div);
    }

    // API Calls
    document.addEventListener('DOMContentLoaded', () => {
        const generateBtn = document.getElementById('generateBtn');
        const savePrefsBtn = document.getElementById('savePrefsBtn');
        const loadingSpinner = document.getElementById('loadingSpinner');
        const planContainer = document.getElementById('planContainer');
        const aiTipText = document.getElementById('aiTipText');
        const downloadPdfBtn = document.getElementById('downloadPdfBtn');

        // PDF Generation
        downloadPdfBtn.addEventListener('click', () => {
            const element = document.getElementById('planContainer');
            const opt = {
                margin: 1,
                filename: 'My_Smart_Study_Plan.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'in', format: 'letter', orientation: 'landscape' }
            };

            const header = document.createElement('div');
            header.innerHTML = `
                <div style="text-align: center; margin-bottom: 20px; font-family: sans-serif;">
                    <h1 style="color: #4361ee;">My Smart Study Plan</h1>
                    <p style="color: #666;">Generated by Antigravity Portal</p>
                </div>
            `;

            const wrapper = document.createElement('div');
            wrapper.style.padding = '20px';
            wrapper.appendChild(header);
            wrapper.appendChild(element.cloneNode(true));

            html2pdf().set(opt).from(wrapper).save();
        });

        // Load AI Tip
        fetch('/api/ai-tip')
            .then(res => res.json())
            .then(data => {
                if (data.tip) aiTipText.innerText = data.tip;
            });

        // Save Preferences
        savePrefsBtn.addEventListener('click', async () => {
            savePrefsBtn.disabled = true;
            savePrefsBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            const subjects = [];
            document.querySelectorAll('input[name="subjects[]"]').forEach(input => {
                if (input.value.trim()) subjects.push({ subject: input.value.trim(), priority: 2 });
            });

            const data = {
                dailyHours: document.getElementById('dailyHoursInput').value,
                startDate: document.getElementById('startDateInput').value,
                endDate: document.getElementById('endDateInput').value,
                focusSubjects: JSON.stringify(subjects)
            };

            try {
                const res = await fetch('/api/preferences', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert('Preferences saved successfully!');
                }
            } catch (err) {
                alert('Error saving preferences');
            } finally {
                savePrefsBtn.disabled = false;
                savePrefsBtn.innerHTML = '<i class="bi bi-save me-2"></i>Save Preferences';
            }
        });

        // Generate AI Plan
        generateBtn.addEventListener('click', async () => {
            generateBtn.disabled = true;
            loadingSpinner.classList.remove('d-none');

            try {
                const res = await fetch('/api/generate-plan', { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    renderPlan(data.plan);
                    downloadPdfBtn.classList.remove('d-none');
                } else {
                    alert('AI Generation failed: ' + data.error);
                }
            } catch (err) {
                alert('Network error during AI generation');
            } finally {
                generateBtn.disabled = false;
                loadingSpinner.classList.add('d-none');
            }
        });

        function renderPlan(plan) {
            let html = '<div class="row g-3">';
            plan.forEach(day => {
                html += `
                <div class="col-md">
                    <div class="day-card-modern p-3 h-100 rounded-4 border bg-white">
                        <h6 class="fw-bold text-uppercase tiny tracking-wider mb-3 text-muted">${day.day}</h6>
                        <div class="slots">
                            ${day.slots.length ? day.slots.map(slot => `
                                <div class="subject-card mb-2 p-3 rounded-4 shadow-sm border-0 bg-light">
                                    <div>
                                        <div class="fw-bold text-dark small">${slot.subject}</div>
                                        <div class="text-muted tiny mt-1"><i class="bi bi-clock-history me-1"></i>${slot.duration}h</div>
                                    </div>
                                    <div class="mt-2 text-end">
                                        <span class="badge badge-soft-primary rounded-pill tiny">${slot.startTime}</span>
                                    </div>
                                </div>
                            `).join('') : `
                                <div class="empty-day text-center py-4 rounded-4">
                                    <i class="bi bi-brightness-high text-warning opacity-50 display-6"></i>
                                    <p class="tiny text-muted mt-2 mb-0">Free Day</p>
                                </div>
                            `}
                        </div>
                    </div>
                </div>
            `;
            });
            html += '</div>';
            planContainer.innerHTML = html;
        }
    });
</script>

<style>
    /* Modern Styling */
    .study-planner-container {
        background-color: #f0f4f8;
        min-height: 90vh;
    }

    .text-primary-gradient {
        background: linear-gradient(45deg, var(--primary), var(--info));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .bg-light-gradient {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .btn-generate-plan {
        background: linear-gradient(45deg, #4361ee, #4895ef);
        color: white;
        border: none;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .btn-generate-plan:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 15px 35px rgba(67, 97, 238, 0.4);
        color: white;
    }

    .day-card-modern {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .subject-card {
        transition: all 0.3s ease;
    }

    .ai-tip-banner {
        background: linear-gradient(135deg, #1e1e2f 0%, #4361ee 100%);
    }

    .ai-icon-box {
        width: 60px;
        height: 60px;
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
    }

    .timeline-event-card {
        transition: all 0.3s ease;
        cursor: default;
    }

    .timeline-event-card:hover {
        transform: translateY(-10px);
    }

    .border-dash {
        border: 2px dashed rgba(255, 255, 255, 0.3);
        background: transparent !important;
        color: #4361ee !important;
    }

    .subject-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--primary);
    }

    .btn-soft-primary {
        background: #e0e7ff;
        color: #4361ee;
    }

    @keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    .floating {
        animation: float 3s ease-in-out infinite;
    }

    .tiny {
        font-size: 0.7rem;
        font-weight: 700;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>