<div class="row">
    <div class="col-12 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="bi {{tracker.icon}}" style="color: {{tracker.color}}"></i> 
                {{tracker.title}}
            </h1>
            <div>
                <a href="/progress/edit/{{tracker._id}}" class="btn btn-outline-primary me-2">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="/progress" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
        <p class="lead">{{tracker.description}}</p>
        <div class="d-flex gap-2">
            <span class="badge" style="background-color: {{tracker.color}}">{{tracker.category}}</span>
            <span class="badge bg-{{#eq tracker.status 'active'}}success{{else}}{{#eq tracker.status 'completed'}}primary{{else}}secondary{{/eq}}{{/eq}}">
                {{tracker.status}}
            </span>
            {{#if tracker.target}}
            <span class="badge bg-info">Target: {{tracker.target}} {{tracker.unit}}</span>
            {{/if}}
            {{#if stats.streak}}
            <span class="badge bg-warning">
                <i class="bi bi-fire"></i> {{stats.streak}} day streak
            </span>
            {{/if}}
        </div>
    </div>

    <!-- Tracker Stats -->
    <div class="col-md-3 mb-4">
        <div class="card" style="border-left: 4px solid {{tracker.color}}">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.totalEntries}}</h1>
                <small>Total Entries</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card" style="border-left: 4px solid {{tracker.color}}">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.todayEntries}}</h1>
                <small>Today's Entries</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card" style="border-left: 4px solid {{tracker.color}}">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{formatNumber (divide stats.totalTimeSpent 60) 1}}</h1>
                <small>Total Hours</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card" style="border-left: 4px solid {{tracker.color}}">
            <div class="card-body text-center p-3">
                <h1 class="display-6">{{stats.totalQuantity}}</h1>
                <small>Total {{tracker.unit}}</small>
            </div>
        </div>
    </div>

    <!-- Progress Bar if target exists -->
    {{#if tracker.target}}
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Progress towards target: {{tracker.target}} {{tracker.unit}}</h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>{{stats.totalQuantity}} / {{tracker.target}} {{tracker.unit}}</span>
                    <span>{{stats.progressPercentage}}%</span>
                </div>
                <div class="progress" style="height: 20px;">
                    <div class="progress-bar" role="progressbar" 
                         style="width: {{stats.progressPercentage}}%; background-color: {{tracker.color}}">
                        {{stats.progressPercentage}}%
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{/if}}

    <!-- Add Today's Entry -->
    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-plus-circle"></i> Add Today's Progress (IST)
                </h5>
            </div>
            <div class="card-body">
                <form action="/progress/entry/add/{{tracker._id}}" method="POST">
                    <div class="mb-3">
                        <label class="form-label">What did you do today? *</label>
                        <textarea class="form-control" name="description" rows="3" 
                                  placeholder="e.g., Solved 5 LeetCode problems, Studied chapter 3, Worked on project API" 
                                  required></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Time spent (minutes)</label>
                            <input type="number" class="form-control" name="timeSpent" 
                                   min="0" placeholder="e.g., 60">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Quantity ({{tracker.unit}})</label>
                            <input type="number" class="form-control" name="quantity" 
                                   min="0" placeholder="e.g., 5">
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Unit (if different)</label>
                        <input type="text" class="form-control" name="unit" 
                               value="{{tracker.unit}}" placeholder="{{tracker.unit}}">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Date (IST)</label>
                        <input type="date" class="form-control" name="entryDate" 
                               value="{{todayISO}}" max="{{todayISO}}">
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Current IST Time</label>
                        <input type="text" class="form-control" value="{{currentTimeIST}}" readonly>
                        <small class="text-muted">Entries will be recorded with current IST time</small>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Notes (Optional)</label>
                        <textarea class="form-control" name="notes" rows="2" 
                                  placeholder="Any additional notes or details"></textarea>
                    </div>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Entry
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

<!-- Recent Entries -->
<div class="col-lg-8 mb-4">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history"></i> Recent Entries (IST)
                </h5>
                <span class="badge bg-primary">{{tracker.dailyEntries.length}} total entries</span>
            </div>
        </div>
        <div class="card-body">
            {{#if tracker.dailyEntries.length}}
                <!-- Sort entries by date (newest first) for display -->
                {{#each (sortEntriesByDate tracker.dailyEntries)}}
                <div class="list-group-item mb-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1">
                                <h6 class="mb-0 me-2">{{description}}</h6>
                                {{#if timeSpent}}
                                <span class="badge bg-info ms-1">
                                    <i class="bi bi-clock"></i> {{timeSpent}} min
                                </span>
                                {{/if}}
                                {{#if quantity}}
                                <span class="badge bg-success ms-1">
                                    <i class="bi bi-hash"></i> {{quantity}} {{../tracker.unit}}
                                </span>
                                {{/if}}
                            </div>
                            {{#if notes}}
                            <p class="small text-muted mb-2">{{notes}}</p>
                            {{/if}}
                            <!-- IST TIME DISPLAY -->
                            <small class="text-muted d-block">
                                <i class="bi bi-clock"></i> {{formatTime date}}
                                <span class="ms-2">•</span>
                                <i class="bi bi-calendar ms-2"></i> {{formatDateOnly date}}
                            </small>
                        </div>
                        <form action="/progress/entry/delete/{{../tracker._id}}/{{@index}}" 
                              method="POST" 
                              onsubmit="return confirm('Delete this entry?')"
                              class="ms-2">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
                {{/each}}
            {{else}}
                <div class="text-center py-5">
                    <i class="bi bi-journal-text display-1 text-muted"></i>
                    <h5 class="text-muted mt-3">No entries yet</h5>
                    <p class="text-muted">Add your first entry to start tracking your progress</p>
                </div>
            {{/if}}
        </div>
    </div>
</div>

    <!-- Calendar View -->
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-calendar3"></i> Activity Calendar
                </h5>
            </div>
            <div class="card-body">
                <div id="progressCalendar"></div>
            </div>
        </div>
    </div>
</div>

<!-- Calendar Script -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.9/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('progressCalendar');
    if (calendarEl) {
        const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek'
            },
            events: '/progress/api/calendar/{{tracker._id}}',
            eventClick: function(info) {
                alert(`Activity: ${info.event.title}\nTime: ${info.event.extendedProps.timeSpent || 0} minutes\nQuantity: ${info.event.extendedProps.quantity || 0} ${info.event.extendedProps.unit || ''}`);
            },
            dateClick: function(info) {
                const dateInput = document.querySelector('input[name="entryDate"]');
                dateInput.value = info.dateStr;
                
                // Scroll to form
                document.querySelector('input[name="description"]').focus();
            },
            timeZone: 'Asia/Kolkata' // Set calendar to IST timezone
        });
        calendar.render();
    }
});
</script>