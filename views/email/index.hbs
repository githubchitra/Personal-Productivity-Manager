<div class="mb-3">
    <button id="addDemoData" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Add More Sample Emails
    </button>
</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Add Handlebars helpers
    Handlebars.registerHelper('eq', (a, b) => a === b);
    Handlebars.registerHelper('gt', (a, b) => a > b);
    Handlebars.registerHelper('add', (a, b) => a + b);
    Handlebars.registerHelper('subtract', (a, b) => a - b);
    Handlebars.registerHelper('range', (start, end) => {
        const arr = [];
        for (let i = start; i <= end; i++) arr.push(i);
        return arr;
    });
    
    // Bulk Selection Functions
    function toggleSelectAll(checkbox) {
        const emailCheckboxes = document.querySelectorAll('.email-checkbox');
        emailCheckboxes.forEach(cb => {
            cb.checked = checkbox.checked;
        });
        updateBulkActions();
    }
    
    function updateBulkActions() {
        const emailCheckboxes = document.querySelectorAll('.email-checkbox');
        const selectedCheckboxes = document.querySelectorAll('.email-checkbox:checked');
        const selectedCount = selectedCheckboxes.length;
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const bulkActions = document.getElementById('bulkActions');
        const selectedCountSpan = document.getElementById('selectedCount');
        
        // Update count
        selectedCountSpan.textContent = selectedCount;
        
        // Show/hide bulk actions
        if (selectedCount > 0) {
            bulkActions.style.display = 'block';
        } else {
            bulkActions.style.display = 'none';
        }
        
        // Update select all checkbox state
        if (selectedCount === 0) {
            selectAllCheckbox.checked = false;
            selectAllCheckbox.indeterminate = false;
        } else if (selectedCount === emailCheckboxes.length) {
            selectAllCheckbox.checked = true;
            selectAllCheckbox.indeterminate = false;
        } else {
            selectAllCheckbox.checked = false;
            selectAllCheckbox.indeterminate = true;
        }
    }
    
    function clearSelection() {
        const emailCheckboxes = document.querySelectorAll('.email-checkbox');
        emailCheckboxes.forEach(cb => {
            cb.checked = false;
        });
        updateBulkActions();
    }
    
    async function deleteSelected() {
        const selectedCheckboxes = document.querySelectorAll('.email-checkbox:checked');
        const selectedCount = selectedCheckboxes.length;
        
        if (selectedCount === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'No emails selected',
                text: 'Please select emails to delete'
            });
            return;
        }
        
        // Ask for confirmation
        const result = await Swal.fire({
            icon: 'warning',
            title: 'Delete Emails?',
            html: `Are you sure you want to delete <strong>${selectedCount}</strong> email(s)?<br>
                  <small class="text-muted">This action cannot be undone.</small>`,
            showCancelButton: true,
            confirmButtonText: 'Yes, delete them',
            confirmButtonColor: '#d33',
            cancelButtonText: 'Cancel'
        });
        
        if (result.isConfirmed) {
            try {
                // Collect selected email IDs
                const emailIds = Array.from(selectedCheckboxes).map(cb => cb.value);
                
                // Submit the form
                const form = document.getElementById('bulkActionForm');
                
                // Create hidden input with CSRF token if needed
                const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
                if (csrfToken) {
                    let csrfInput = form.querySelector('input[name="_csrf"]');
                    if (!csrfInput) {
                        csrfInput = document.createElement('input');
                        csrfInput.type = 'hidden';
                        csrfInput.name = '_csrf';
                        csrfInput.value = csrfToken;
                        form.appendChild(csrfInput);
                    }
                }
                
                // Submit form
                const response = await fetch('/email/bulk-delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ emailIds: emailIds })
                });
                
                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Deleted!',
                        text: `Successfully deleted ${selectedCount} email(s)`,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    throw new Error('Delete failed');
                }
                
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to delete emails. Please try again.'
                });
                console.error('Delete error:', error);
            }
        }
    }
    
    // Manual sync
    async function manualSync() {
        try {
            const response = await fetch('/email/sync', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            
            const result = await response.json();
            
            if (result.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Sync Complete!',
                    text: `Fetched ${result.totalFetched} emails, saved ${result.saved} notifications`,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Sync Failed',
                    text: result.message
                });
            }
        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to sync emails'
            });
        }
    }
    
    // Toggle unread filter
    function toggleUnreadFilter() {
        const unreadOnly = document.getElementById('unreadFilter').checked;
        const url = new URL(window.location.href);
        
        if (unreadOnly) {
            url.searchParams.set('unread', 'true');
        } else {
            url.searchParams.delete('unread');
        }
        
        window.location.href = url.toString();
    }
    
    // Auto-refresh every 5 minutes
    setInterval(() => {
        fetch('/email/api/stats')
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update unread count in navbar
                    const unreadBadge = document.querySelector('.unread-count');
                    if (unreadBadge && data.stats.unread > 0) {
                        unreadBadge.textContent = data.stats.unread;
                        unreadBadge.classList.remove('d-none');
                    }
                }
            });
    }, 5 * 60 * 1000); // 5 minutes
    
    // Initialize bulk actions
    document.addEventListener('DOMContentLoaded', function() {
        updateBulkActions();
    });
</script>

<script>
// Sync emails
document.getElementById('syncEmails')?.addEventListener('click', async function() {
    const btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Syncing...';
    
    try {
        const response = await fetch('/email/sync', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const result = await response.json();
        
        if (result.success) {
            if (result.count > 0) {
                alert(`✅ Synced ${result.count} new emails!`);
            } else {
                alert('✅ No new emails found.');
            }
            window.location.reload();
        } else if (result.needsReauth) {
            alert('⚠️ Session expired. Please reconnect your Gmail.');
            window.location.href = '/email/connect';
        } else {
            alert('Error: ' + result.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Sync Now';
        }
    } catch (error) {
        alert('Network error. Please try again.');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Sync Now';
    }
});

// Disconnect Gmail
document.getElementById('disconnectGmail')?.addEventListener('click', async function() {
    if (confirm('Are you sure you want to disconnect your Gmail account?')) {
        const response = await fetch('/email/disconnect', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const result = await response.json();
        if (result.success) {
            alert('Gmail disconnected successfully.');
            window.location.reload();
        }
    }
});
</script>